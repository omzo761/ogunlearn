---
const stats = [
  { bold: '+ 230%', text: 'de cyberattaques sur les entreprises africaines depuis 2023' },
  { bold: '14% des entreprises', text: 'du continent disposent d\'un RSSI formé en interne', prefix: 'Seules ' },
  { bold: 'ISO 27001', text: 'aux banques et fintech', prefix: 'L\'UEMOA impose désormais la conformité ' },
  { bold: 'RSSI', text: 'est classé parmi les 5 plus tendus à recruter en Afrique de l\'Ouest', prefix: 'Le métier de ' },
];
---

<section class="section">
  <div class="container why">
    <div>
      <span class="section__eyebrow">Le contexte</span>
      <h2>Pourquoi se former à la <em>cybersécurité</em> en Afrique aujourd'hui</h2>
      <ul class="why__list">
        {stats.map(s => (
          <li>
            <span class="arrow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
            <span>{s.prefix}<strong>{s.bold}</strong> {s.text}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="why__visual">
      <div class="why__shape why__shape--1">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2 L20 6 V12 C20 17 16 21 12 22 C8 21 4 17 4 12 V6 Z"/>
          <path d="M9 12 L11 14 L15 10"/>
        </svg>
      </div>
      <div class="why__shape why__shape--2">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>
      <div class="why__shape why__shape--3">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="6"/>
          <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .section { padding: 110px 0; position: relative; }

  .why {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  @media (max-width: 980px) {
    .why { grid-template-columns: 1fr; gap: 48px; }
  }

  .section__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--coral);
    letter-spacing: .12em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 20px;
    padding: 5px 12px;
    background: var(--coral-tint);
    border-radius: var(--r-pill);
  }
  .section__eyebrow::before {
    content: "✦";
    font-size: 14px;
  }

  .why h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(36px, 4.4vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 32px;
  }
  .why h2 :global(em) { font-style: italic; color: var(--coral); }

  .why__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .why__list li {
    display: flex;
    gap: 16px;
    font-size: 16.5px;
    line-height: 1.5;
    color: var(--ink-soft);
  }
  .why__list .arrow {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    background: var(--indigo);
    color: var(--paper);
    border-radius: 50%;
    display: grid;
    place-items: center;
    margin-top: 1px;
  }
  .why__list .arrow svg { width: 14px; height: 14px; }
  .why__list :global(strong) { color: var(--ink); font-weight: 600; }

  .why__visual {
    position: relative;
    aspect-ratio: 1;
    max-width: 480px;
    margin: 0 auto;
    width: 100%;
  }
  .why__shape {
    position: absolute;
    border-radius: var(--r-xl);
  }
  .why__shape--1 {
    top: 0;
    left: 0;
    width: 60%;
    height: 60%;
    background: var(--coral);
    box-shadow: 0 30px 60px -30px rgba(232,93,60,.5);
  }
  .why__shape--2 {
    bottom: 0;
    right: 0;
    width: 55%;
    height: 55%;
    background: var(--indigo);
    box-shadow: 0 30px 60px -30px rgba(30,42,74,.5);
  }
  .why__shape--3 {
    top: 30%;
    right: 12%;
    width: 38%;
    height: 38%;
    background: var(--gold);
    border-radius: 50%;
    box-shadow: 0 20px 40px -20px rgba(212,166,71,.6);
  }
  .why__shape svg {
    position: absolute;
    width: 50%;
    height: 50%;
    top: 25%;
    left: 25%;
    color: var(--paper);
    opacity: .9;
  }
</style>
