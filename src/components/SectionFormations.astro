    features: [
      { icon: '🎓', text: 'Attestation de suivi' },
      { icon: '⌛', text: '4 heures, 12 min/semaine' },
      { icon: '🛜', text: 'Format mobile-first' },
      { icon: '💼', text: 'Quiz de validation' },
