---
// Data centralisée — sera bougée vers src/data/formations.json plus tard
const formations = [
  {
    id: 'rssi-africain',
    tag: 'Formation Métier',
    badge: 'Nouveau',
    style: 'dark',
    title: 'RSSI africain — la transformation',
    desc: 'Le programme flagship pour piloter une fonction sécurité de bout en bout dans le contexte UEMOA.',
    features: [
      { icon: '🎓', text: 'Titre RNCP Niveau 6 — RSSI' },
      { icon: '⌛', text: '6 mois à temps partiel' },
      { icon: '🛜', text: 'Formation 100% à distance' },
      { icon: '💼', text: '1 projet professionnel évalué' },
      { icon: '🤝', text: 'Mentorat 1-1 avec un RSSI en poste' },
      { icon: '✅', text: 'Éligible CPF, OPCO, France Travail' },
    ],
    href: '/formations/rssi-africain',
  },
  {
    id: 'pen-tester',
    tag: 'Formation Métier',
    badge: 'Star',
    style: 'featured',
    title: 'Pen Tester offensif',
    desc: 'OWASP, Burp, Metasploit. Apprendre à attaquer pour mieux défendre. Lab privé fourni.',
    features: [
      { icon: '🎓', text: 'Certification CEH alignée' },
