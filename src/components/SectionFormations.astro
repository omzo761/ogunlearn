      { icon: '🛜', text: 'Formation à distance + labs' },
      { icon: '💼', text: '1 projet de pentest réel' },
      { icon: '🤝', text: 'Mentor expert pentester' },
      { icon: '✅', text: 'Éligible aux financements' },
    ],
    href: '/formations/pen-tester',
  },
  {
    id: 'cloud-security',
    tag: 'Formation Compétence',
    style: 'default',
    title: 'Sécurité Cloud AWS / GCP',
    desc: 'IAM, segmentation, monitoring. Adaptée aux migrations massives en cours sur le continent.',
    features: [
      { icon: '🎓', text: 'Certification de compétences' },
      { icon: '⌛', text: '3 mois à temps partiel' },
      { icon: '🛜', text: 'Formation à distance' },
      { icon: '💼', text: '1 projet cloud réel' },
      { icon: '🤝', text: 'Soutien individuel' },
      { icon: '✅', text: 'Éligible au financement OPCO' },
    ],
    href: '/formations/cloud-security',
  },
  {
