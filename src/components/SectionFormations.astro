  {
    id: 'splunk',
    tag: 'Formation Outil',
    style: 'default',
    title: 'Maîtrise de Splunk SIEM',
    desc: 'Centralisez vos logs, détectez les menaces, automatisez vos réponses incident.',
    features: [
      { icon: '🎓', text: 'Certification Splunk Core' },
