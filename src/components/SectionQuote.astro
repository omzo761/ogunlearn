---
const quote = {
  text: 'Formation à la pédagogie bien pensée, mentors de haut vol. En six mois, j\'ai pu structurer la fonction sécurité de ma banque et obtenir la certification ISO.',
  emphasis: 'Je recommande sans réserve.',
  authorInitials: 'AD',
  author: 'Adriane Diagne',
  authorRole: 'Alumni Bootcamp · RSSI @Banque CFA',
};
---

<section class="quote">
  <svg class="quote__star quote__star--1" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <path d="M50 0 L60 40 L100 50 L60 60 L50 100 L40 60 L0 50 L40 40 Z"/>
  </svg>
  <svg class="quote__star quote__star--2" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
    <path d="M50 0 L60 40 L100 50 L60 60 L50 100 L40 60 L0 50 L40 40 Z"/>
  </svg>

  <div class="container quote__inner">
    <div class="quote__pilot">
      <div class="trustpilot__stars">
        {Array.from({ length: 5 }).map(() => (
          <span>
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/>
            </svg>
          </span>
        ))}
      </div>
      Avis vérifié Trustpilot
    </div>

    <blockquote>
      « {quote.text} <em>{quote.emphasis}</em> »
    </blockquote>

    <div class="quote__author">
      <span class="avatar">{quote.authorInitials}</span>
      <div class="info">
        <b>{quote.author}</b>
        <small>{quote.authorRole}</small>
      </div>
    </div>
  </div>
</section>

<style>
  .quote {
    background: var(--ink);
    color: var(--paper);
    padding: 130px 0;
    position: relative;
    overflow: hidden;
  }
  .quote__star {
    position: absolute;
    width: 140px; height: 140px;
    color: var(--coral);
    opacity: .15;
    animation: spin 25s linear infinite;
  }
  .quote__star--1 { top: 50px; left: 8%; }
  .quote__star--2 { bottom: 50px; right: 10%; }

  .quote__inner {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }
  .quote__pilot {
    display: inline-flex; align-items: center; gap: 12px;
    padding: 10px 16px;
    background: rgba(245,239,230,.08);
    border: 1px solid rgba(245,239,230,.15);
    border-radius: var(--r-pill);
    margin-bottom: 36px;
    font-size: 13px; color: var(--paper); font-weight: 500;
  }
  .trustpilot__stars { display: flex; gap: 2px; }
  .trustpilot__stars span {
    width: 18px; height: 18px;
    background: #00B67A;
    display: grid; place-items: center;
    color: white;
  }
  .trustpilot__stars span svg { width: 11px; height: 11px; }

  .quote blockquote {
    font-family: var(--font-display);
    font-weight: 300; font-style: italic;
    font-size: clamp(28px, 3.6vw, 44px);
    line-height: 1.22; letter-spacing: -0.022em;
    margin-bottom: 40px;
  }
  .quote blockquote em { font-style: italic; color: var(--coral); }

  .quote__author { display: inline-flex; align-items: center; gap: 16px; }
  .quote__author .avatar {
    width: 60px; height: 60px; border-radius: 50%;
    background: var(--coral);
    display: grid; place-items: center;
    font-family: var(--font-display);
    font-weight: 600; font-size: 22px; color: var(--paper);
  }
  .quote__author .info { text-align: left; }
  .quote__author b { display: block; font-weight: 600; font-size: 16px; }
  .quote__author small { color: var(--ink-faint); font-size: 13px; }
</style>
